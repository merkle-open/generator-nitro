<div class="container">
	<div class="row">
		<div class="col-md-8 offset-md-2"><% if (options.exampleCode) { %>
			<h1 style="font-size:2em;margin-top:1em;">{% pattern name='icon' additionalData={ icon: 'nitro' } %}&nbsp;Nitro example page</h1>
			{% pattern name='example' data='example' %}
			{% pattern name='example' data='example-highlight' %}<% if (options.clientTpl) { %>
			{% pattern name='example' data='example-template' %}<% } %>
			<div class="a-box"><a href="example-patterns">more examples</a></div><% } else { %>
			<h1>Index</h1><% } %>
		</div>
	</div>
</div>
